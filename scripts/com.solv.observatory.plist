<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.solv.observatory</string>

    <key>ProgramArguments</key>
    <array>
        <string>REPO_PATH/scripts/refresh.sh</string>
    </array>

    <!-- Run at 8am daily. If the Mac is asleep at 8am, it runs as soon as it wakes up. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>REPO_PATH/scripts/refresh.log</string>
    <key>StandardErrorPath</key>
    <string>REPO_PATH/scripts/refresh.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
